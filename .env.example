# OpenCode API Keys
# Descomenta y agrega tus keys segun los providers que uses
GOOGLE_API_KEY=pon-tu-google-api-key-aqui

# OpenAI (ChatGPT, GPT-4, DALL-E, Whisper)
# OPENAI_API_KEY=sk-...

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# Ollama (local) — no necesita key, solo la URL
# OLLAMA_BASE_URL=http://localhost:11434
