{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-sol",
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6
  },
  "tool_output": { "max_lines": 200, "max_bytes": 8192 },
  "plugin": [
    "__HOME__/.config/opencode/plugins/personalities.js",
    "__HOME__/.config/opencode/plugins/guardrails.js",
    "__HOME__/.config/opencode/plugins/checkpoints.js",
    "__HOME__/.config/opencode/plugins/kanban.js",
    "__HOME__/.config/opencode/plugins/validator.js",
    "__HOME__/.config/opencode/plugins/session-metrics.js"
  ]
}
