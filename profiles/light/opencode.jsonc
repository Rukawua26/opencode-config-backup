{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4-mini",
  "small_model": "openai/gpt-5.4-mini",
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3
  },
  "tool_output": { "max_lines": 80, "max_bytes": 4096 },
  "plugin": [
    "__HOME__/.config/opencode/plugins/guardrails.js",
    "__HOME__/.config/opencode/plugins/checkpoints.js",
    "__HOME__/.config/opencode/plugins/validator.js",
    "__HOME__/.config/opencode/plugins/session-metrics.js"
  ],
  "mcp": {
    "context7": {
      "enabled": false
    },
    "diagram-generator": {
      "enabled": false
    }
  }
}
