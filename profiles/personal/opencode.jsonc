{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-flash-lite",
  "compaction": { "auto": true, "tail_turns": 15 },
  "tool_output": { "max_lines": 100, "max_bytes": 4096 },
  "plugin": [
    "__HOME__/.config/opencode/plugins/memory.js",
    "__HOME__/.config/opencode/plugins/personalities.js",
    "__HOME__/.config/opencode/plugins/guardrails.js",
    "__HOME__/.config/opencode/plugins/checkpoints.js"
  ]
}
