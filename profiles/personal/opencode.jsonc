{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-flash-lite",
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "truncation_policy": {
      "mode": "tokens",
      "limit": 32000
    }
  },
  "tool_output": { "max_lines": 100, "max_bytes": 4096 },
  "plugin": [
    "/home/miguel/.config/opencode/plugins/memory.js",
    "/home/miguel/.config/opencode/plugins/personalities.js",
    "/home/miguel/.config/opencode/plugins/guardrails.js",
    "/home/miguel/.config/opencode/plugins/checkpoints.js",
    "/home/miguel/.config/opencode/plugins/validator.js"
  ]
}
