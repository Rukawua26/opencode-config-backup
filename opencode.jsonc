{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "google/gemini-2.5-flash-lite",
  "experimental": {
    "batch_tool": true,
    "disable_paste_summary": true
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6
  },
  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  },
  "skills": {
    "paths": ["__HOME__/opencode-custom/skills"]
  },
  "plugin": [
    "./plugins/memory-v2.js",
    "./plugins/personalities.js",
    "./plugins/guardrails.js",
    "./plugins/checkpoints.js",
    "./plugins/kanban.js",
    "./plugins/sandbox.js",
    "./plugins/validator.js"
  ],
  "mcp": {
    "local-model-router": {
      "type": "local",
      "command": [
        "/usr/bin/env",
        "-i",
        "HOME=__HOME__",
        "PATH=/usr/bin:/bin",
        "XDG_RUNTIME_DIR=/run/user/1000",
        "DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus",
        "/usr/bin/node",
        "__HOME__/.config/opencode/mcp/local-model-router.js"
      ],
      "enabled": true,
      "timeout": 150000
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": false
    },
    "diagram-generator": {
      "type": "local",
      "command": ["npx", "-y", "mcp-diagram-generator"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--user-data-dir",
        "__HOME__/GHL/data/mcp-browser-profile"
      ],
      "enabled": false
    }
  }
}
