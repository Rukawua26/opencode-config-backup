{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 4
  },
  "tool_output": {
    "max_lines": 100,
    "max_bytes": 4096
  },
  "plugin": [
    "./plugins/memory.js",
    "./plugins/personalities.js",
    "./plugins/guardrails.js",
    "./plugins/checkpoints.js",
    "./plugins/kanban.js",
    "./plugins/sandbox.js"
  ],
  "mcp": {
    "cheap-llm": {
      "type": "local",
      "command": ["node", "__HOME__/.config/opencode/mcp/cheap-llm.js"],
      "enabled": true
    }
  }
}
