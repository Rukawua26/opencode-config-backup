{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "openai/gpt-5.4-mini",
  "subagent_depth": 1,
  "experimental": {
    "batch_tool": true,
    "disable_paste_summary": true
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 6
  },
  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  },
  "attachment": {
    "image": {
      "auto_resize": true,
      "max_width": 1200,
      "max_height": 1200
    }
  },
  "agent": {
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    },
    "scout": {
      "model": "openai/gpt-5.4-mini",
      "steps": 8,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    },
    "title": {
      "model": "openai/gpt-5.4-mini"
    },
    "summary": {
      "model": "openai/gpt-5.4-mini"
    },
    "compaction": {
      "model": "openai/gpt-5.6-sol"
    }
  },
  "skills": {
    "paths": ["__HOME__/opencode-custom/skills"]
  },
  "plugin": [
    "./plugins/personalities.js",
    "./plugins/guardrails.js",
    "./plugins/checkpoints.js",
    "./plugins/kanban.js",
    "./plugins/sandbox.js",
    "./plugins/validator.js",
    "./plugins/session-metrics.js"
  ],
  "mcp": {
    "local-model-router": {
      "type": "local",
      "command": [
        "/usr/bin/env",
        "-i",
        "HOME=__HOME__",
        "PATH=/usr/bin:/bin",
        "XDG_RUNTIME_DIR=/run/user/1000",
        "DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus",
        "/usr/bin/node",
        "__HOME__/.config/opencode/mcp/local-model-router.js"
      ],
      "enabled": true,
      "timeout": 150000
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": false
    },
    "diagram-generator": {
      "type": "local",
      "command": ["npx", "-y", "mcp-diagram-generator"],
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest",
        "--user-data-dir",
        "__HOME__/GHL/data/mcp-browser-profile"
      ],
      "enabled": false
    }
  }
}
