{
  "$schema": "https://opencode.ai/config.json",
  "small_model": "google/gemini-2.5-flash-lite",
  "experimental": {
    "batch_tool": true,
    "disable_paste_summary": true
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 4
  },
  "tool_output": {
    "max_lines": 100,
    "max_bytes": 4096
  },
  "skills": {
    "paths": ["/home/miguel/opencode-custom/skills"]
  },
  "plugin": [
    "./plugins/memory.js",
    "./plugins/memory-v2.js",
    "./plugins/personalities.js",
    "./plugins/guardrails.js",
    "./plugins/checkpoints.js",
    "./plugins/kanban.js",
    "./plugins/sandbox.js",
    "./plugins/validator.js"
  ],
  "mcp": {
    "cheap-llm": {
      "type": "local",
      "command": ["node", "/home/miguel/.config/opencode/mcp/cheap-llm.js"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true
    }
  }
}
