#!/usr/bin/env bash
set -euo pipefail

section() {
  printf '\n== %s ==\n' "$1"
}

section "Unload local models if Ollama is reachable"
if curl --silent --show-error --max-time 3 http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
  ollama stop qwen2.5-coder:3b >/dev/null 2>&1 || true
  ollama stop qwen3.5:4b >/dev/null 2>&1 || true
  ollama stop phi4-mini:latest >/dev/null 2>&1 || true
  ollama ps || true
else
  echo "Ollama is not reachable; skipping model unload."
fi

section "Stop idle timer and Ollama service"
systemctl --user stop ollama-idle-stop.timer >/dev/null 2>&1 || true
systemctl --user stop ollama-idle-stop.service >/dev/null 2>&1 || true
systemctl --user stop ollama.service >/dev/null 2>&1 || true
systemctl --user disable ollama.service >/dev/null 2>&1 || true
systemctl --user disable ollama-idle-stop.timer >/dev/null 2>&1 || true

section "Final state"
systemctl --user show ollama.service -p ActiveState -p UnitFileState
systemctl --user show ollama-idle-stop.timer -p ActiveState -p UnitFileState

cat <<'EOF'

Local AI stack stopped.

OpenCode MCP router remains configured, but Ollama and the cleanup timer are inactive.
route_model can still recommend without starting Ollama.
Any ask_* local model call will start Ollama lazily again.
EOF
