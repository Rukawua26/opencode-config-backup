#!/usr/bin/env bash
set -euo pipefail

OPENCODE_DIR="/home/miguel/.config/opencode"
ROUTER="$OPENCODE_DIR/mcp/local-model-router.js"

section() {
  printf '\n== %s ==\n' "$1"
}

section "OpenCode MCP"
opencode mcp list

section "Initial Ollama state"
systemctl --user show ollama.service -p ActiveState -p UnitFileState
systemctl --user show ollama-idle-stop.timer -p ActiveState -p UnitFileState

section "Router recommendation without starting Ollama"
cd "$OPENCODE_DIR"
node --input-type=module -e "import {callTool} from './mcp/local-model-router.js'; const r=await callTool('route_model',{task:'Implementar una función Python con tests'}); console.log(r.content[0].text);"
systemctl --user show ollama.service -p ActiveState

section "Code specialist: qwen2.5-coder:3b"
node --input-type=module -e "import {callTool} from './mcp/local-model-router.js'; const r=await callTool('ask_code_model',{task:'Implementar una función pequeña',prompt:'Responde exactamente LOCAL_CODE_OK.'}); console.log(r.content[0].text);"

section "Reasoning specialist: phi4-mini"
node --input-type=module -e "import {callTool} from './mcp/local-model-router.js'; const r=await callTool('ask_reasoning_model',{task:'Analizar una decisión lógica',prompt:'Responde exactamente LOCAL_REASONING_OK.'}); console.log(r.content[0].text);"

section "Cloud guard check"
node --input-type=module -e "import {callTool} from './mcp/local-model-router.js'; const r=await callTool('ask_best_model',{task:'Diseñar arquitectura de pagos en producción',prompt:'Propón una arquitectura segura para pagos en producción.'}); console.log(r.content[0].text);"

section "Loaded local models"
ollama ps || true

section "Service state after local use"
systemctl --user show ollama.service -p ActiveState
systemctl --user show ollama-idle-stop.timer -p ActiveState

cat <<'EOF'

Local AI stack is ready.

Use inside OpenCode:
- route_model: recommendation only; does not start Ollama.
- ask_best_model: choose local/cloud automatically.
- ask_code_model: qwen2.5-coder:3b.
- ask_chat_model: qwen3.5:4b; use only for short prompts because memory is tight.
- ask_reasoning_model: phi4-mini:latest.

To shut everything down now:
  /home/miguel/.config/opencode/bin/local-ai-off
EOF
