{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-flash-lite",
  "small_model": "google/gemini-2.5-flash-lite",
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3
  },
  "tool_output": { "max_lines": 80, "max_bytes": 4096 },
  "plugin": [
    "/home/miguel/.config/opencode/plugins/memory.js",
    "/home/miguel/.config/opencode/plugins/guardrails.js",
    "/home/miguel/.config/opencode/plugins/checkpoints.js",
    "/home/miguel/.config/opencode/plugins/validator.js"
  ],
  "mcp": {
    "cheap-llm": {
      "type": "local",
      "command": ["node", "/home/miguel/.config/opencode/mcp/cheap-llm.js"],
      "enabled": true
    },
    "context7": {
      "enabled": false
    },
    "diagram-generator": {
      "enabled": false
    }
  }
}
